{
  "name": "ssh-ui",
  "displayName": "SSH UI",
  "description": "VSCode Extension: Manage and connect to SSH hosts from UI",
  "version": "0.1.0",
  "publisher": "pinaki-das-sage",
  "author": {
    "name": "Pinaki Das",
    "email": "pinaki17@gmail.com",
    "url": "https://github.com/pinaki-das-sage/ssh-ui"
  },
  "icon": "icon.png",
  "repository": "https://github.com/pinaki-das-sage/ssh-ui.git",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sshHostsViewContainer",
          "title": "SSH UI",
          "icon": "resources/viewContainerIcon.svg"
        }
      ]
    },
    "views": {
      "sshHostsViewContainer": [
        {
          "id": "sshHostsView",
          "name": "SSH UI",
          "icon": "resources/viewContainerIcon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ssh-ui.editConfig",
        "title": "Edit configuration file",
        "category": "SSH UI",
        "icon": "resources/editConfig.svg"
      },
      {
        "command": "ssh-ui.addHost",
        "title": "Add Host",
        "category": "SSH UI",
        "icon": "resources/addHost.svg"
      },
      {
        "command": "ssh-ui.removeHost",
        "title": "Remove Host",
        "category": "SSH UI",
        "icon": "resources/removeHost.svg"
      },
      {
        "command": "ssh-ui.savePassword",
        "title": "Save password for host",
        "category": "SSH UI",
        "icon": "resources/savePassword.svg"
      },
      {
        "command": "ssh-ui.deletePassword",
        "title": "Delete saved password for host",
        "category": "SSH UI",
        "icon": "resources/deletePassword.svg"
      },
      {
        "command": "ssh-ui.connect",
        "title": "Connect",
        "category": "SSH UI",
        "icon": "$(plug)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ssh-ui.addHost",
          "when": "view == sshHostsView",
          "group": "navigation@1"
        },
        {
          "command": "ssh-ui.editConfig",
          "when": "view == sshHostsView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ssh-ui.connect",
          "when": "view == sshHostsView && viewItem == host",
          "group": "inline@0"
        },
        {
          "command": "ssh-ui.savePassword",
          "when": "view == sshHostsView && viewItem == host",
          "group": "inline@1"
        },
        {
          "command": "ssh-ui.removeHost",
          "when": "view == sshHostsView && viewItem == host",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'Prepublish script - No direct execution required'",
    "lint": "eslint .",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "eslint": "^9.16.0",
    "vscode": "^1.1.37"
  }
}
